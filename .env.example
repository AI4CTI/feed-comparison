# feed-comparison environment file template.
#
# Copy this file to `.env` and fill in only the credentials for the
# feeds you actually plan to use. `feed-comparison` ignores feeds
# whose credentials are not set, with a clear error at fetch time
# rather than silently producing empty results.
#
# DO NOT commit your filled-in `.env` — the repository's `.gitignore`
# excludes it by default.

# --- MISP (self-hosted) ---
# MISP_URL=https://misp.example.org
# MISP_KEY=changeme

# --- PhishTank ---
# Free username; used as the User-Agent string on the download endpoint.
# PHISHTANK_USERNAME=anonymous

# --- urlscan.io ---
# Search API endpoint and personal API token.
# URLSCAN_URL=https://urlscan.io/api/v1/search/
# URLSCAN_TOKEN=changeme

# --- Tool-wide ---
# Default output directory for CSVs and plots (overridden by --output-dir).
# FEED_COMPARISON_OUTPUT_DIR=./output
